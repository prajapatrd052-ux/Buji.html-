rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required, immutable)
    //   - displayName: string (optional)
    //   - preferences: map (optional)
    //     - sassyLevel: number
    //     - theme: string
    //   - memories: list of strings (optional)
    //   - updatedAt: timestamp (optional)
    //   - role: string (optional, admin only can set)
    //
    // Collection: users/{uid}/conversations
    // Document ID: {convId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - summary: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "prajapatrd052@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('memories' in data) || (data.memories is list && data.memories.size() < 100)) &&
             (!('preferences' in data) || (data.preferences is map)) &&
             (!('role' in data) || (data.role is string && (data.role == 'user' || isAdmin())));
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['uid', 'summary', 'timestamp']) &&
             data.uid is string &&
             data.summary is string && data.summary.size() < 5000 &&
             data.timestamp is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
      
      match /conversations/{convId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidConversation(request.resource.data);
      }
    }
  }
}
